{
  "name": "@next-md-blog/core",
  "version": "1.0.6",
  "description": "A React library for parsing and displaying markdown blog posts in Next.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "pnpm -C ../.. exec eslint packages/core",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "react",
    "nextjs",
    "markdown",
    "blog",
    "mdx",
    "content"
  ],
  "author": "next-md-blog",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/next-md-blog/next-md-blog.git",
    "directory": "packages/core"
  },
  "homepage": "https://www.next-md-blog.com",
  "bugs": {
    "url": "https://github.com/next-md-blog/next-md-blog/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "react-markdown": "^10.1.0",
    "rehype-react": "^8.0.0",
    "remark": "^15.0.1",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.2.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "next": "^16.2.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
